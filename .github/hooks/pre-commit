#!/bin/bash
# Pre-commit hook: blocks commits containing real secrets
# Install: cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "Running secret scan..."

FOUND=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

for file in $STAGED_FILES; do
    # Skip the hook file itself
    if [[ "$file" == *"pre-commit"* ]]; then
        continue
    fi

    CONTENT=$(git show ":$file" 2>/dev/null)
    if [ -z "$CONTENT" ]; then
        continue
    fi

    # Check for real API keys (not pattern references)
    if echo "$CONTENT" | grep -qP 'sk-ant-api\w{2}-[A-Za-z0-9_-]{20,}'; then
        echo -e "${RED}BLOCKED: Anthropic API key found in: $file${NC}"
        FOUND=1
    fi

    if echo "$CONTENT" | grep -qP 'GOCSPX-[A-Za-z0-9_-]{20,}'; then
        echo -e "${RED}BLOCKED: Google client secret found in: $file${NC}"
        FOUND=1
    fi

    if echo "$CONTENT" | grep -qP '"refresh_token"\s*:\s*"1//[A-Za-z0-9_-]{20,}"'; then
        echo -e "${RED}BLOCKED: OAuth refresh token found in: $file${NC}"
        FOUND=1
    fi

    if echo "$CONTENT" | grep -qP 'ya29\.[A-Za-z0-9_-]{50,}'; then
        echo -e "${RED}BLOCKED: Google access token found in: $file${NC}"
        FOUND=1
    fi

    if echo "$CONTENT" | grep -qP 'AIzaSy[A-Za-z0-9_-]{30,}'; then
        echo -e "${RED}BLOCKED: Google API key found in: $file${NC}"
        FOUND=1
    fi

    if echo "$CONTENT" | grep -qP '-----BEGIN (RSA |EC )?PRIVATE KEY-----'; then
        echo -e "${RED}BLOCKED: Private key found in: $file${NC}"
        FOUND=1
    fi
done

if [ $FOUND -eq 1 ]; then
    echo ""
    echo -e "${RED}COMMIT REJECTED — Remove secrets before committing.${NC}"
    exit 1
fi

echo -e "${GREEN}Secret scan passed.${NC}"
exit 0
