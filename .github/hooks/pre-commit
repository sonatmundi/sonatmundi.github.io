#!/bin/bash
# Pre-commit hook: blocks commits containing secrets
# Install: cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "Running secret scan..."

# Patterns that should NEVER appear in committed code
PATTERNS=(
    'sk-ant-api'
    'GOCSPX-'
    'ya29\.'
    'AIzaSy'
    'refresh_token'
    'client_secret.*GOCSPX'
    'gmail_app_password'
    'BEGIN.*PRIVATE KEY'
    'BEGIN.*RSA'
)

FOUND=0
for pattern in "${PATTERNS[@]}"; do
    MATCHES=$(git diff --cached --diff-filter=ACMR -S "$pattern" --name-only 2>/dev/null)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}BLOCKED: Secret pattern '$pattern' found in:${NC}"
        echo "$MATCHES" | while read -r file; do
            echo "  - $file"
        done
        FOUND=1
    fi
done

# Also check staged file contents directly
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
for file in $STAGED_FILES; do
    if git show ":$file" 2>/dev/null | grep -qE 'sk-ant-api|GOCSPX-|ya29\.|"refresh_token"' 2>/dev/null; then
        echo -e "${RED}BLOCKED: Secrets detected in staged file: $file${NC}"
        FOUND=1
    fi
done

if [ $FOUND -eq 1 ]; then
    echo ""
    echo -e "${RED}COMMIT REJECTED — Remove secrets before committing.${NC}"
    echo "If this is a false positive, use: git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}Secret scan passed.${NC}"
exit 0
